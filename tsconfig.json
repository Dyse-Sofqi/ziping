{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2020",
		"moduleResolution": "node",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"sourceMap": true,
		"lib": [
			"ES2020",
			"DOM"
		],
		"skipLibCheck": true,
		"baseUrl": ".",
		"resolveJsonModule": true,
		"paths": {
			"obsidian": [
				"node_modules/obsidian/types"
			]
		}
	},
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ]
}